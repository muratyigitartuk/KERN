# ============================================================================
# KERN Configuration — copy this file to .env and edit for your deployment
# cp .env.example .env
# ============================================================================

# --- Core ---
KERN_USER_TITLE=sir                      # How KERN addresses the user
KERN_TIMEZONE=Europe/Berlin              # IANA timezone (e.g., Europe/Berlin, America/New_York)
KERN_DB_PATH=kern.db                     # Path to the main SQLite database
KERN_SYSTEM_DB_PATH=kern-system.db       # Path to the system-level SQLite database
KERN_PRODUCT_POSTURE=production          # "production" or "personal" — controls UI and feature gates

# --- Storage Paths ---
KERN_ROOT_PATH=.kern                     # Root directory for all KERN data
KERN_PROFILE_ROOT=.kern/profiles         # Per-user profile storage
KERN_BACKUP_ROOT=.kern/backups           # Encrypted backup bundles
KERN_DOCUMENT_ROOT=.kern/documents       # Ingested document storage
KERN_ATTACHMENT_ROOT=.kern/attachments   # Email and chat attachments
KERN_ARCHIVE_ROOT=.kern/archives         # Archived data
KERN_MEETING_ROOT=.kern/meetings         # Meeting transcripts and notes

# --- Voice Output ---
KERN_SPEAKING_ENABLED=false              # Enable TTS voice output (true/false)
KERN_TTS_PREFERENCE=piper                # TTS engine: "piper" or "system"
# KERN_PIPER_BINARY=                     # Path to Piper TTS binary (required if TTS enabled)
# KERN_PIPER_MODEL=                      # Path to Piper ONNX voice model

# --- Runtime Mode ---
KERN_LOCAL_MODE=true                     # Prefer local-first runtime behavior when available

# --- Cognition ---
KERN_COGNITION_BACKEND=hybrid            # Cognition backend: "hybrid" or "llama_cpp"
# KERN_COGNITION_MODEL=                 # Model name for the cognition backend
# KERN_EMBED_MODEL=                     # Embedding model name
# KERN_MODEL_MODE=auto                  # Model routing mode: "auto", "fast", "deep", "off"
# KERN_FAST_MODEL_PATH=                 # Path to fast/small GGUF model
# KERN_DEEP_MODEL_PATH=                 # Path to deep/large GGUF model
# KERN_PROMPT_CACHE_ENABLED=true        # Enable prompt caching (true/false)
# KERN_PROMPT_CACHE_SIZE=24             # Max cached prompts
# KERN_INTENT_FALLBACK_MODE=off         # Intent fallback: "off" or "llm"
# KERN_INTENT_FALLBACK_MIN_CONFIDENCE=0.6  # Min confidence before fallback triggers (0.0-1.0)

# --- LLM Server ---
KERN_LLM_ENABLED=false                   # Enable LLM inference (true/false)
KERN_LLM_LOCAL_ONLY=true                 # Require the LLM endpoint to stay on localhost
KERN_ALLOW_CLOUD_LLM=false               # Reserved future opt-in; keep false for privacy-first rollout
KERN_LLAMA_SERVER_URL=http://127.0.0.1:8080  # URL of local llama-server
# KERN_LLAMA_SERVER_BINARY=              # Optional explicit path to llama-server.exe
# KERN_LLAMA_SERVER_MODEL_PATH=          # GGUF file or folder path for the local llama-server launcher
# KERN_LLAMA_SERVER_LORA_PATH=           # Optional GGUF LoRA adapter path for llama-server experiments
# KERN_LLM_MODEL=                        # API alias to request from llama-server, e.g. eurollm9b
# KERN_LLAMA_SERVER_TIMEOUT=30.0        # LLM request timeout in seconds
KERN_LLM_MAX_TOKENS=1024                # Max tokens per LLM response
# KERN_LLM_TEMPERATURE=0.3             # LLM sampling temperature (0.0-2.0)
KERN_LLM_CONTEXT_WINDOW=8192            # LLM context window size in tokens

# --- HF Adapter Server (reference-quality tuned model path) ---
# KERN_HF_ADAPTER_MODEL=                 # Base HF model ID, e.g. Qwen/Qwen2.5-14B-Instruct
# KERN_HF_ADAPTER_PATH=                  # PEFT adapter directory path
# KERN_HF_ADAPTER_ALIAS=                 # Served alias, e.g. KERN-qwen
# KERN_HF_ADAPTER_PORT=8080             # Local port for the adapter server
# KERN_HF_ADAPTER_TRUST_REMOTE_CODE=true  # Required for some model families
# KERN_HF_ADAPTER_LOAD_IN_4BIT=true       # Requires bitsandbytes / compatible backend

# --- Security & Encryption ---
KERN_AUDIT_ENABLED=true                  # Enable audit trail logging (true/false)
KERN_POLICY_MODE=personal               # "corporate" or "personal" — controls document classification gates
# KERN_POLICY_ALLOW_EXTERNAL_NETWORK=false    # Allow outbound network in corporate mode
# KERN_POLICY_RESTRICT_SENSITIVE_READS=true   # Require classification for sensitive reads
# KERN_POLICY_RESTRICT_SENSITIVE_EXPORTS=true # Require classification for exports
KERN_DB_ENCRYPTION_MODE=fernet           # Database encryption: "fernet" or "off" ("none" accepted as legacy alias)
KERN_ARTIFACT_ENCRYPTION_ENABLED=true    # Encrypt stored artifacts (true/false)
KERN_KEY_DERIVATION_VERSION=v1           # Key derivation scheme version
# KERN_PROFILE_KEY_ROTATION_REQUIRED=false  # Force key rotation on next login

# --- Retention (GDPR/DSGVO compliance) ---
KERN_RETENTION_DOCUMENTS_DAYS=3650       # Document retention period in days (3650 = ~10 years)
KERN_RETENTION_EMAIL_DAYS=730            # Email retention period in days (730 = 2 years)
KERN_RETENTION_TRANSCRIPTS_DAYS=365      # Transcript retention in days (365 = 1 year)
KERN_RETENTION_AUDIT_DAYS=2555           # Audit log retention in days (2555 = ~7 years)
KERN_RETENTION_BACKUPS_DAYS=365          # Backup retention in days (365 = 1 year)
# KERN_RETENTION_ENFORCEMENT_ENABLED=true  # Auto-delete expired data (true/false)
# KERN_RETENTION_RUN_INTERVAL_HOURS=12    # Hours between retention enforcement runs

# --- Email (optional, requires IMAP/SMTP) ---
# KERN_IMAP_HOST=                       # IMAP server hostname (e.g., imap.gmail.com)
# KERN_SMTP_HOST=                       # SMTP server hostname (e.g., smtp.gmail.com)
# KERN_EMAIL_USERNAME=                  # Email login username
# KERN_EMAIL_PASSWORD=                  # Email login password
# KERN_EMAIL_ADDRESS=                   # Email address for sending

# --- Sync, RAG, Push, Meetings (optional) ---
# KERN_RAG_ENABLED=false                # Enable retrieval-augmented generation (true/false)
# KERN_RAG_EMBED_MODEL=                 # Embedding model for RAG indexing
# KERN_RAG_INDEX_VERSION=v1             # RAG index schema version
# KERN_EMBED_MODEL_PATH=                # Path to local embedding model file
# KERN_VEC_ENABLED=false                # Enable vector search (true/false)
# KERN_RAG_TOP_K=12                     # Number of RAG candidates to retrieve
# KERN_RAG_RERANK_TOP_N=4              # Number of results after reranking
# KERN_RAG_MIN_SCORE=0.1               # Minimum relevance score for RAG results (0.0-1.0)
# KERN_RAG_RERANKER_BACKEND=llm        # Reranker backend: "llm" or "cross-encoder"
# KERN_NTFY_TOPIC=                      # ntfy.sh push notification topic
# KERN_NTFY_BASE_URL=                   # ntfy.sh server URL
# KERN_SYNC_MODE=off                    # Sync mode: "off", "webdav", "nextcloud"
# KERN_NEXTCLOUD_URL=                   # Nextcloud server URL for sync

# --- Network Monitor ---
KERN_NETWORK_MONITOR_ENABLED=true        # Enable network connection monitoring (true/false)
# KERN_NETWORK_MONITOR_INTERVAL=30      # Seconds between network scans
# KERN_NETWORK_ALLOWED_HOSTS=127.0.0.1,localhost,::1  # Comma-separated allowed hosts

# --- Scheduler ---
KERN_SCHEDULER_ENABLED=true              # Enable cron-like task scheduler (true/false)
# KERN_SCHEDULER_RETRY_DELAY_MINUTES=10 # Minutes between task retries
# KERN_SCHEDULER_MAX_RETRIES=2          # Max retry attempts per task
# KERN_SCHEDULER_STALE_RUN_MINUTES=45   # Minutes before a running task is considered stale

# --- Watchers ---
# KERN_FILE_WATCH_DIRS=                 # Comma-separated directories to watch for changes
# KERN_FILE_WATCH_RECONCILE_MINUTES=30  # Minutes between file watch reconciliation
# KERN_INBOX_WATCH_INTERVAL=300         # Seconds between inbox checks
# KERN_PROACTIVE_SCAN_INTERVAL=600      # Seconds between proactive alert scans

# --- Runtime Tuning ---
KERN_PROACTIVE_ENABLED=true              # Enable proactive alerts and watchers (true/false)
KERN_HEARTBEAT_SECONDS=2.0              # WebSocket heartbeat interval in seconds
KERN_MONITOR_INTERVAL_SECONDS=0.35      # System monitor poll interval in seconds
KERN_SNAPSHOT_DIRTY_DEBOUNCE_MS=120     # Debounce for snapshot dirty flag in milliseconds
KERN_CONTEXT_REFRESH_SECONDS=1.5        # Context window refresh interval in seconds
KERN_CAPABILITY_REFRESH_SECONDS=3.0     # Capability refresh interval in seconds
KERN_SEED_DEFAULTS=false                 # Seed default data on first run (true/false)
# KERN_CONTEXT_WINDOW_ENABLED=true      # Enable desktop context awareness (true/false)
# KERN_CONTEXT_MEDIA_ENABLED=true       # Include media context (true/false)
# KERN_CONTEXT_CLIPBOARD_ENABLED=false  # Include clipboard context (true/false)
# KERN_CONTEXT_CLIPBOARD_MAX_CHARS=280  # Max clipboard characters to capture

# --- Voice Tuning ---
# KERN_TTS_VOICE=                       # TTS voice name (engine-specific)
# KERN_TTS_SPEED=1.0                    # TTS playback speed multiplier

# --- GDPR / DPO Contact ---
# KERN_DPO_CONTACT_NAME=                # Data Protection Officer name
# KERN_DPO_CONTACT_EMAIL=               # Data Protection Officer email

# --- UI ---
KERN_UI_LANGUAGE=en                      # UI language: "en" or "de"

# --- Experimental ---
# KERN_UPDATE_CHANNEL=stable            # Update channel: "stable" or "beta"
# KERN_PWA_ENABLED=false                # Enable progressive web app mode (true/false)
